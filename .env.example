# Donald — environment. Copy to .env and fill in. Nothing here is required to
# import the packages or run the unit tests; each key only unlocks a live path.

# --- Agent core (donald/) ---
# The model brain. Without a key, Donald falls back to the offline mock brain.
ANTHROPIC_API_KEY=
# DONALD_BRAIN=claude          # or "mock"
# DONALD_MODEL=claude-opus-4-8

# --- Gateway brain via OpenRouter (or any OpenAI-compatible provider) ---
# Point Donald at OpenRouter instead of Anthropic — no Anthropic key needed:
# DONALD_PROVIDER=openai
# DONALD_BASE_URL=https://openrouter.ai/api/v1
# DONALD_API_KEY=sk-or-...                 # your OpenRouter key
# DONALD_MODEL=anthropic/claude-sonnet-4   # any OpenRouter model slug you use
# OPENROUTER_REFERER=https://your-app-url  # optional attribution (OpenRouter)
# OPENROUTER_TITLE=Donald OS               # optional attribution
#
# Hermes has its OWN model (configured in ~/.hermes/.env); the gateway just
# talks to its local API server:
# HERMES_BASE_URL=http://127.0.0.1:8642
# HERMES_API_KEY=change-me-local-dev

# --- Backend (backend/) : accounts, auth, encrypted integration tokens ---
# Database. Unset -> SQLite at ./donald_data/backend.db (dev default).
# Postgres in prod:
# DATABASE_URL=postgresql://user:pass@host:5432/donald
#
# Fernet key that encrypts per-user integration tokens at rest. REQUIRED in
# production — without it, tokens are encrypted with an ephemeral key and won't
# survive a restart. Generate once:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BACKEND_SECRET_KEY=

# Memory embeddings (M2). Default is an offline lexical embedder (no key). For
# conceptual recall, point at any OpenAI-compatible /embeddings endpoint:
# EMBEDDINGS_PROVIDER=remote
# EMBEDDINGS_BASE_URL=https://api.openai.com/v1
# EMBEDDINGS_API_KEY=
# EMBEDDINGS_MODEL=text-embedding-3-small
# EMBEDDINGS_DIM=1536
# NOTE: switching providers requires re-embedding existing memory.

# --- OAuth broker (M4) : per-user integration connect/refresh ---
# Where providers redirect back after consent (your public base URL):
# OAUTH_REDIRECT_BASE=http://localhost:8000
# Optional dedicated secret for signing OAuth state (falls back to BACKEND_SECRET_KEY):
# OAUTH_STATE_SECRET=
# Per-provider app credentials (a provider is only connectable once set):
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=

# --- Billing (M5) : Stripe subscriptions ---
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PRICE_ID=price_...            # the recurring price users subscribe to
# STRIPE_WEBHOOK_SECRET=whsec_...      # verify inbound Stripe webhooks
# BILLING_SUCCESS_URL / BILLING_CANCEL_URL default to OAUTH_REDIRECT_BASE/app.

# --- Desktop auto-update (M6) ---
# UPDATE_MANIFEST_PATH=/path/to/latest.json   # served at /api/update/{target}/{arch}/{version}

# --- Gateway (gateway/) : streaming server the UI talks to ---
# HERMES_API_KEY=
# Donald's real voice (ElevenLabs). VOICE_ENABLED must be true AND the key set;
# point ELEVENLABS_VOICE_ID at your cloned Donald voice. Then every reply streams
# back as audio the web shell plays (falls back to the browser voice otherwise).
# VOICE_ENABLED=true
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=your_cloned_donald_voice_id
# ELEVENLABS_MODEL=eleven_multilingual_v2

# --- Voice (optional, donald[voice]) ---
# DEEPGRAM_API_KEY=
