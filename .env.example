# Server auth
BEARER_TOKEN=your-long-random-secret-here

# API keys
ANTHROPIC_API_KEY=sk-ant-...
DEEPGRAM_API_KEY=your-deepgram-api-key
ELEVENLABS_API_KEY=sk_...

# Google APIs (optional, for calendar/email)
# Provide JSON credentials file paths or leave empty for stubbed mode
GOOGLE_CALENDAR_CREDENTIALS_JSON=
GMAIL_CREDENTIALS_JSON=

# Server config
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Database
DB_PATH=donald.db

# TTS cache TTL (seconds)
TTS_CACHE_TTL_SECONDS=300
