# Copy this file to ".env" and fill in your key:  cp .env.example .env
# run.sh loads .env automatically so you don't have to export it each time.

# Required — your Anthropic API key (Donald's brain). Get one at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — path to the Vosk speech model for the always-on wake listener.
# Defaults to ./model (created by `./run.sh --listen`).
# VOSK_MODEL=model
