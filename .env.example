# Copy to .env and fill in. .env is git-ignored — never commit real keys.
#   cp .env.example .env

# Tier 1+ : the brain. Required.
ANTHROPIC_API_KEY=sk-ant-...

# Tier 3 : voice. Only needed once you add push-to-talk.
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# Tier 6 : real email for the gated send_message tool. Configure email.* in
# config.yaml too. For Gmail, use an App Password here (not your login password).
SMTP_USERNAME=
SMTP_PASSWORD=
