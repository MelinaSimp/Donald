# Donald configuration. Copy this file to `.env` and fill in what you need.
# Each tier reads only the keys it requires — you can fill these in as you go.

# ── Tier 0 / Tier 1: the brain ────────────────────────────────────────────
# Get one at https://console.anthropic.com/. Without it, Donald runs in
# DONALD_BRAIN=mock mode (canned replies) so you can still test the loop.
ANTHROPIC_API_KEY=
# Which brain to use: "claude" (real) or "mock" (offline, no key needed).
DONALD_BRAIN=claude
# Model for the brain. See https://docs.anthropic.com/en/docs/about-claude/models
DONALD_MODEL=claude-opus-4-8

# ── Tier 2: voice (optional, install with `pip install -e ".[voice]"`) ─────
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
# ElevenLabs voice id. "Rachel" default is 21m00Tcm4TlvDq8ikWAM.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Tier 1: web search tool ────────────────────────────────────────────────
# Donald's web_search tool uses Claude's server-side web search by default
# (no extra key). To use Brave Search instead, set this.
BRAVE_API_KEY=

# ── Storage ────────────────────────────────────────────────────────────────
# Where memory (Tier 3) lives. Defaults to ./donald_data/donald.db
DONALD_DB_PATH=
# Root directory the shell/file tool is allowed to touch (Tier 5 safety).
# Defaults to ./donald_workspace
DONALD_WORKSPACE=

# ── Tier 4: proactive loop ─────────────────────────────────────────────────
# How often (seconds) the background loop checks if Donald should reach out.
DONALD_PROACTIVE_INTERVAL=60
# Master switch for proactive behaviour. "off" until you trust it.
DONALD_PROACTIVE=off
