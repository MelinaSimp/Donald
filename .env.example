# Prism — environment. Copy to .env and fill in. Nothing here is required to
# import the package or run the unit tests; each key only unlocks a live path.

# --- Planning loop + Claude Code composer (Tier 3) ---
# Needed for the agent's planning loop AND for the `claude` CLI subprocess.
ANTHROPIC_API_KEY=

# Model overrides (optional)
# PRISM_PLANNING_MODEL=claude-sonnet-4-6
# PRISM_COMPOSER_MODEL=claude-sonnet-4-6
# PRISM_COMPOSER_MAX_TURNS=40

# Hard per-dispatch cost ceiling in USD (default 6.0)
# PRISM_COST_CAP_USD=6.0

# --- AI image generation (Tier 5) ---
# Image-gen models are NOT in Gemini's free tier — billing must be enabled on
# the AI Studio project or the model rejects with quota=0.
GEMINI_API_KEY=

# --- Project registry (Tier 1) ---
# Either point at an explicit slug->path registry JSON...
# PRISM_REGISTRY=/abs/path/to/registry.json
# ...or use the convention base dir (resolves PRISM_PROJECTS_BASE/<slug>).
# PRISM_PROJECTS_BASE=/abs/path/to/projects
