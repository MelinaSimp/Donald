# ── Donald gateway configuration ────────────────────────────────────────────
# Copy to gateway/.env (gitignored) and fill in. Nothing secret lives in code.

# --- Donald brain (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-...
DONALD_MODEL=claude-opus-4-8
DONALD_MAX_TOKENS=1024
DONALD_TEMPERATURE=0.8

# --- Hermes (the local agent) ---
# Two ways to reach Hermes; pick one with HERMES_MODE.
#
# HERMES_MODE=cli  -> drive Hermes' one-shot CLI (works with the Dockerised
#                     NousResearch Hermes stack; no HTTP API needed). The
#                     gateway must run on the same host, with Docker access.
# HERMES_MODE=http -> talk to an OpenAI-compatible Hermes API server.
HERMES_MODE=cli

# -- CLI mode (HERMES_MODE=cli) --
# Name of the Hermes agent container (docker ps). Leave blank if `hermes` runs
# directly on this host (not in Docker).
HERMES_DOCKER_CONTAINER=hermes-workspace-rzuj-hermes-agent-1
HERMES_CLI_PATH=/opt/hermes/.venv/bin/hermes
HERMES_CLI_EXTRA_ARGS=--yolo          # auto-approve tool actions in one-shot runs
HERMES_MODEL=hermes                   # "hermes" = use the container's configured default
HERMES_TIMEOUT_S=300                  # local models cold-load slowly; be generous

# -- HTTP mode (HERMES_MODE=http) --
HERMES_BASE_URL=http://127.0.0.1:8642
HERMES_API_KEY=change-me-local-dev

# --- Voice (ElevenLabs TTS — the Trump-style voice) ---
VOICE_ENABLED=true
ELEVENLABS_API_KEY=                       # <-- only thing still needed for voice
ELEVENLABS_VOICE_ID=DAqNbWkj293fwKQlkwBq  # Donald's voice
ELEVENLABS_MODEL=eleven_multilingual_v2

# --- Gateway server (what your UI connects to) ---
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8765
# Comma-separated origins your Claude-designed UI is served from.
GATEWAY_CORS_ORIGINS=*
