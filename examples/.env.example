# Database connection for the assistant app.
# Copy to .env and fill in. NEVER commit the real .env. Secrets come from your
# password manager / secret store — they are never stored in the repo.

# Which database to talk to: "local" (fallback / rollback) or "cloud" (droplet).
DB_MODE=local

# --- Local mode (your pre-migration database; keep as instant rollback) ------
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=assistant
LOCAL_DB_USER=postgres
LOCAL_DB_PASSWORD=
LOCAL_DB_SSLMODE=disable

# --- Cloud mode (DigitalOcean droplet, TLS required) -------------------------
CLOUD_DB_HOST=203.0.113.10        # your droplet public IPv4
CLOUD_DB_PORT=5432
CLOUD_DB_NAME=assistant
CLOUD_DB_USER=assistant_app
CLOUD_DB_PASSWORD=                # paste from your password manager (do NOT commit)
CLOUD_DB_SSLMODE=require          # self-signed cert on bare IP; use verify-full only with a domain + CA-signed cert
